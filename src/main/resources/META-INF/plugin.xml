<idea-plugin>
    <id>rsdltj.myplugin</id>
    <name>AI Assistant Plugin</name>
    <vendor>Rafael Santiago De La Torre Jiménez</vendor>
    <description>This AI plugin helps maintain coding conventions, as well as offer some quick quality of life utilities</description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="rsdltj.myplugin.settings.OllamaSettings"/>
        <applicationConfigurable
                parentId="tools"
                instance="rsdltj.myplugin.settings.OllamaConfigurable"
                id="rsdltj.myplugin.settings.OllamaConfigurable"
                displayName="Ollama AI"/>
        <applicationService serviceImplementation="rsdltj.myplugin.core.OllamaProcessManager"/>
        <postStartupActivity implementation="rsdltj.myplugin.core.OllamaStartupActivity"/>

    </extensions>

    <actions>
        <action id="rsdltj.myplugin.actions.TestOllamaAction"
                class="rsdltj.myplugin.actions.TestAction"
                text="Test Ollama Connection"
                description="Send a test prompt to your local Ollama instance">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="rsdltj.myplugin.actions.commenting.CommentAction"
                class="rsdltj.myplugin.actions.commenting.CommentAction"
                text="Explain This Code"
                description="Get AI explanation for selected Java code">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt E"/>
        </action>
        <action id="rsdltj.myplugin.actions.convention.ConventionAction"
                class="rsdltj.myplugin.actions.convention.ConventionAction"
                text="Fix Conventions"
                description="Check and fix Java naming conventions in the current file">
            <add-to-group group-id="EditorPopupMenu"
                          anchor="after"
                          relative-to-action="rsdltj.myplugin.actions.commenting.CommentAction"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift alt Z" />
        </action>
    </actions>
</idea-plugin>